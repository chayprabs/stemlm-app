  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/katex": "^0.16.7",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
