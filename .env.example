# stemLM analytics configuration (GA4 Measurement Protocol)
#
# Copy this file to `.env` and fill in the values to enable analytics.
# Until these are set, the analytics module is a safe no-op (nothing is sent).
#
# How to get these:
#   1. Create a GA4 property at https://analytics.google.com
#   2. Admin -> Data Streams -> Web -> Create stream  => Measurement ID (G-XXXXXXXXXX)
#   3. In that stream: Measurement Protocol API secrets -> Create  => API secret
#
# These are read at build time by wxt.config.ts.

STEMLM_GA_MEASUREMENT_ID=
STEMLM_GA_API_SECRET=
